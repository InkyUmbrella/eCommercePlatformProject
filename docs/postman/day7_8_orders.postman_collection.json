{
  "info": {
    "_postman_id": "1aa5fc6d-8a49-4c1d-b84f-e8a8cdf9f9d7",
    "name": "Day7-8 Orders APIs",
    "description": "Day7-8 for role-1: order confirm/create + lifecycle + refund/logistics",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Login (save access token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let jsonData = {};",
              "try { jsonData = pm.response.json(); } catch (e) { jsonData = {}; }",
              "const access = jsonData?.data?.access;",
              "if (access) pm.collectionVariables.set('access_token', access);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"test_user_001\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/users/login/",
          "host": ["{{base_url}}"],
          "path": ["api", "users", "login", ""]
        }
      },
      "response": []
    },
    {
      "name": "1. Confirm Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{}" },
        "url": {
          "raw": "{{base_url}}/api/orders/confirm/",
          "host": ["{{base_url}}"],
          "path": ["api", "orders", "confirm", ""]
        }
      },
      "response": []
    },
    {
      "name": "2. Create Order (save order_id)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let jsonData = {};",
              "try { jsonData = pm.response.json(); } catch (e) { jsonData = {}; }",
              "const id = jsonData?.data?.order_id;",
              "if (id) pm.collectionVariables.set('order_id', String(id));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"address_id\": {{address_id}}\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/orders/",
          "host": ["{{base_url}}"],
          "path": ["api", "orders", ""]
        }
      },
      "response": []
    },
    {
      "name": "3. Pay Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{}" },
        "url": {
          "raw": "{{base_url}}/api/orders/{{order_id}}/pay/",
          "host": ["{{base_url}}"],
          "path": ["api", "orders", "{{order_id}}", "pay", ""]
        }
      },
      "response": []
    },
    {
      "name": "4. List Orders",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let jsonData = {};",
              "try { jsonData = pm.response.json(); } catch (e) { jsonData = {}; }",
              "const firstId = jsonData?.data?.results?.[0]?.id;",
              "if (firstId) pm.collectionVariables.set('order_id', String(firstId));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/orders/?page=1&page_size=10",
          "host": ["{{base_url}}"],
          "path": ["api", "orders", ""],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "page_size", "value": "10" }
          ]
        }
      },
      "response": []
    },
    {
      "name": "5. Order Detail",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/orders/{{order_id}}/",
          "host": ["{{base_url}}"],
          "path": ["api", "orders", "{{order_id}}", ""]
        }
      },
      "response": []
    },
    {
      "name": "6. Cancel Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{}" },
        "url": {
          "raw": "{{base_url}}/api/orders/{{order_id}}/cancel/",
          "host": ["{{base_url}}"],
          "path": ["api", "orders", "{{order_id}}", "cancel", ""]
        }
      },
      "response": []
    },
    {
      "name": "7. Confirm Receive",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{}" },
        "url": {
          "raw": "{{base_url}}/api/orders/{{order_id}}/confirm-receive/",
          "host": ["{{base_url}}"],
          "path": ["api", "orders", "{{order_id}}", "confirm-receive", ""]
        }
      },
      "response": []
    },
    {
      "name": "8. Start Refund",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{}" },
        "url": {
          "raw": "{{base_url}}/api/orders/{{order_id}}/refund/",
          "host": ["{{base_url}}"],
          "path": ["api", "orders", "{{order_id}}", "refund", ""]
        }
      },
      "response": []
    },
    {
      "name": "9. Complete Refund",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "body": { "mode": "raw", "raw": "{}" },
        "url": {
          "raw": "{{base_url}}/api/orders/{{order_id}}/refund-complete/",
          "host": ["{{base_url}}"],
          "path": ["api", "orders", "{{order_id}}", "refund-complete", ""]
        }
      },
      "response": []
    },
    {
      "name": "10. Get Logistics",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{access_token}}" }
        ],
        "url": {
          "raw": "{{base_url}}/api/orders/{{order_id}}/logistics/",
          "host": ["{{base_url}}"],
          "path": ["api", "orders", "{{order_id}}", "logistics", ""]
        }
      },
      "response": []
    }
  ],
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "access_token", "value": "" },
    { "key": "address_id", "value": "" },
    { "key": "order_id", "value": "" }
  ]
}
