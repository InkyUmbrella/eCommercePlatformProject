{% extends "admin/base_site.html" %}
{% load i18n %}

{% block content %}
<div id="content-main">
 <div class="app-list">
 {% for app in app_list %}
 <div class="app-{{ app.app_label }}">
 <h2>
 {% if app.app_label == 'products' %}
 商品管理
 {% else %}
 {{ app.name }}
 {% endif %}
 </h2>
 <ul class="model-list">
 {% for model in app.models %}
 <li>
 <a href="{{ model.admin_url }}">{{ model.name }}</a>
 </li>
 {% endfor %}
 </ul>
 </div>
 {% endfor %}
 </div>

 {% if recent_actions %}
 <div class="recent-actions">
 <h2>近期操作</h2>
 <ul>
 {% for action in recent_actions %}
 <li class="action">
 {{ action.action_text|safe }}
 <span class="action-time">{{ action.action_time }}</span>
 </li>
 {% endfor %}
 </ul>
 <p class="view-all"><a href="{{ recent_actions_url }}">查看全部操作</a></p>
 </div>
 {% endif %}
</div>
{% endblock %}
