{
  "info": {
    "_postman_id": "2fe5ea20-8f10-44fe-95e4-6bd88f4dd92a",
    "name": "Day4 Addresses APIs",
    "description": "Day4 for role-1: address CRUD + set-default",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0. Login (save access/refresh token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let jsonData = {};",
              "try {",
              "    jsonData = pm.response.json();",
              "} catch (e) {",
              "    jsonData = {};",
              "}",
              "",
              "const access = jsonData?.data?.access;",
              "const refresh = jsonData?.data?.refresh;",
              "if (access) pm.collectionVariables.set('access_token', access);",
              "if (refresh) pm.collectionVariables.set('refresh_token', refresh);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"test_user_001\",\n  \"password\": \"123456\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/users/login/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users",
            "login",
            ""
          ]
        }
      },
      "response": []
    },
    {
      "name": "1. Create Address #1 (auto default)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "let jsonData = {};",
              "try {",
              "    jsonData = pm.response.json();",
              "} catch (e) {",
              "    jsonData = {};",
              "}",
              "",
              "const id = jsonData?.data?.id;",
              "if (id) pm.collectionVariables.set('address_id_1', String(id));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Alice\",\n  \"address\": \"Shanghai Pudong Century Ave 100\",\n  \"phone_number\": \"13800000001\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/users/addresses/",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "users",
            "addresses",
            ""
          ]
        }
      },
      "response": []
    },
